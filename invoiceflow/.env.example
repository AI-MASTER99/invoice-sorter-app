# Invoice Sorter — environment variables
#
# Copy this file to `.env` for local development, or configure the same
# keys in Render → Environment for production. The app refuses to start
# if any of the REQUIRED ones are missing or set to a known-default
# value.

# === REQUIRED ===

# Long random string used to sign session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# DO NOT use "dev-secret-change-me" or other obvious defaults — the
# startup check rejects them.
SECRET_KEY=

# Initial password for the seeded `admin` user in the default company.
# Change it via the UI after first login. DO NOT use "changeme".
APP_PASSWORD=

# Anthropic API key (https://console.anthropic.com/settings/keys).
ANTHROPIC_API_KEY=

# Supabase project URL + service-role key (used for storage + DB).
SUPABASE_URL=
SUPABASE_KEY=


# === OPTIONAL ===

# Set to 1 for local development — relaxes session-cookie security
# (https_only off) and adds localhost to the CORS whitelist.
# DEV_MODE=1

# Override the default Claude models (see main.py for current defaults).
# AI_MODEL_PRIMARY=claude-opus-4-7
# AI_MODEL_LIGHT=claude-sonnet-4-6

# Single-model override — sets BOTH primary and light to the same value.
# Useful for cost control or rollback.
# AI_MODEL=
