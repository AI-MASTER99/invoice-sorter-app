# Invoice Sorter — environment variables
#
# Copy this file to `.env` for local development, or configure the same
# keys in Render → Environment for production. The app refuses to start
# if any of the REQUIRED ones are missing or set to a known-default
# value.

# === REQUIRED ===

# Long random string used to sign session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# DO NOT use "dev-secret-change-me" or other obvious defaults — the
# startup check rejects them.
SECRET_KEY=

# Initial password for the seeded `admin` user in the default company.
# Change it via the UI after first login. DO NOT use "changeme".
APP_PASSWORD=

# Anthropic API key (https://console.anthropic.com/settings/keys).
ANTHROPIC_API_KEY=

# Supabase project — URL + three keys (Dashboard → Settings → API).
#   SUPABASE_KEY        : the service-role key. Full access, bypasses RLS.
#                         Used by login, the queue worker, startup and storage.
#   SUPABASE_ANON_KEY   : the public "anon" key — the legacy JWT-based one
#                         (a long `eyJ...` string, NOT a `sb_publishable_...`
#                         key and NOT a key-ID). Needed for the per-request
#                         user-scoped client (Phase B / Row-Level Security).
#   SUPABASE_JWT_SECRET : the project's JWT secret (Settings → API → JWT
#                         Settings → reveal — a ~40-char string). The app mints
#                         per-user JWTs with it, so it MUST be the exact secret
#                         that signs your anon key, or every RLS read fails.
# The app refuses to start if any of these three is missing.
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=


# === FEATURE FLAGS ===

# Turn ON the per-client commodity-code list (the "V-lookup"). When set to 1
# AND the invoice's supplier matches a client, the export columns are filled
# from that client's product list: the LIST description, the full 10-digit
# code (so the TARIC column gets its last-2 subcode), and the CDS document
# fields. Products not in the list are flagged `*** NOT IN LIST ***`.
#
# When this is unset or not "1", the app falls back to the RAW invoice data:
# the original (e.g. Italian) descriptions, the 8-digit invoice codes, an
# EMPTY TARIC column and NO not-in-list flags. Easy to miss — it fails
# silently, not with an error.
#
# Production runs with this ON, so set it locally too or your exports won't
# match production.
USE_CLIENT_LIST=1


# === OPTIONAL ===

# Storage retention (days). The per-invoice files — the original upload and
# the two generated Excel exports — are only needed until the user downloads
# their result. A daily background purge deletes storage objects older than
# this. Kept forever they filled the free-tier Storage quota and took the app
# down. The per-client V-lookup lists (Postgres tables) are NEVER touched.
# 0 disables the purge. Default 7.
# STORAGE_RETENTION_DAYS=7

# Break-glass admin recovery. Set to 1 to RESET the default `admin` user's
# password to the current APP_PASSWORD on every boot — use only when the
# admin password is lost and nobody can log in. Set APP_PASSWORD to the new
# password you want, deploy with this flag, log in, then REMOVE this flag
# (while it's set, every deploy re-resets the password).
# FORCE_ADMIN_RESET=1

# Set to 1 for local development — relaxes session-cookie security
# (https_only off) and adds localhost to the CORS whitelist.
# DEV_MODE=1

# Override the default Claude models (see main.py for current defaults).
# AI_MODEL_PRIMARY=claude-opus-4-8
# AI_MODEL_LIGHT=claude-sonnet-4-6

# Single-model override — sets BOTH primary and light to the same value.
# Useful for cost control or rollback.
# AI_MODEL=
